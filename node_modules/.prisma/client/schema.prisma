generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String // hash bcrypt, jamais en clair
  name      String?
  createdAt DateTime @default(now())
  scans     Scan[]
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Scan {
  id          String       @id @default(uuid())
  targetUrl   String
  status      ScanStatus   @default(PENDING)
  globalScore Int?
  startedAt   DateTime     @default(now())
  finishedAt  DateTime?
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  results     ScanResult[]

  @@index([userId])
}

enum ResultStatus {
  PASS
  WARNING
  FAIL
}

model ScanResult {
  id         String       @id @default(uuid())
  moduleName String // ex: "SSL_TLS", "HTTP_HEADERS", "COOKIES"...
  status     ResultStatus
  details    String // explication lisible du résultat
  score      Int // contribution au score global (0-100)
  scanId     String
  scan       Scan         @relation(fields: [scanId], references: [id])

  @@index([scanId])
}
